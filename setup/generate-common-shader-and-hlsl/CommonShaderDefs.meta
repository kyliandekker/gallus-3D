cbuffer ShaderTransform // (register=b0)
{
    float4x4 			WorldViewProj;
    float4x4 			WorldMatrix;
};

cbuffer TextureUV // (register=b1)
{
    float4 				uv;
};

cbuffer MaterialData // (register=b2)
{
	uint 				EnableLighting;
    float3 				Padding0;
    float4 				DiffuseColor;
    float 				Metallic;
    float 				Smoothness;
	float2 				Padding1;
};

cbuffer DirectionalLightData // (register=b3)
{
	uint 				DirectionalLightEnabled;
    float3 				LightDirection;
    float4 				LightColor;
	float 				AmbientIntensity;
	float				Padding2[3];
};

cbuffer SkinningData // (register=b4)
{
	float4x4 			Bones[64];
};

vertex_input VSInput
{
    float3 				POSITION			POSITION;
    float2 				TEXCOORD			TEXCOORD0;
    float3 				NORMAL				NORMAL;
    uint4 				JOINTS				JOINTS;
    float4 				WEIGHTS				WEIGHTS;
};

pixel_input PSInput
{
    float4 				POSITION			SV_POSITION;
    float2 				TEXCOORD			TEXCOORD0;
    float3 				NORMAL				NORMAL;
    float4 				COLOR				COLOR;
};

root_parameters
{
    TRANSFORM				transform					b0				cbuffer;
    SPRITE_UV				textureUV					b1				cbuffer;
    MATERIAL         		material					b2				cbuffer;
    DIRECTIONAL_LIGHT		directionalLightData		b3				cbuffer;
    SKINNING_DATA			skinningData				b4				cbuffer;
    TEX_SRV					spriteTexture				t0				Texture2D;
    SAMPLER_STATE			samplerState				s0				SamplerState;
};